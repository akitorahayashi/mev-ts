[
  {
    "context": "ProjectPanel",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-r": "workspace::CopyRelativePath",
      "ctrl-a": "workspace::CopyPath"
    }
  },
  {
    "context": "Pane",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ],
      "ctrl-alt-o": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false
        }
      ],
      "ctrl-alt-c": [
        "pane::CloseCleanItems",
        {
          "close_pinned": false
        }
      ],
      "ctrl-alt-a": [
        "pane::CloseAllItems",
        {
          "close_pinned": false
        }
      ],
      "ctrl-alt-p": "pane::TogglePinTab"
    }
  },
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-i": "agent::ToggleFocus"
    }
  },
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-i": "agent::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "shift-enter": ["terminal::SendText", "\n"],
      "ctrl-cmd-n": "workspace::NewTerminal",
      "ctrl-cmd-s": "pane::SplitRight",
      "cmd-i": "agent::ToggleFocus"
    }
  }
]
