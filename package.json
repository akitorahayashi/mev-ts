{
  "name": "mev",
  "version": "0.1.0",
  "description": "Local IaC for macOS",
  "packageManager": "bun@1.3.14",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mev": "./src/main.ts"
  },
  "scripts": {
    "premev": "bun run codegen",
    "mev": "bun src/main.ts",
    "codegen": "bun scripts/generate-assets.ts",
    "prebuild": "mkdir -p dist && bun run codegen",
    "build": "bun build src/main.ts --compile --outfile dist/mev && rm -f .*.bun-build",
    "pretest": "bun run codegen",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "precheck": "bun run codegen",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.2.1",
    "clipanion": "^4.0.0-rc.4",
    "js-yaml": "^5.1.0",
    "listr2": "^10.2.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "^4.0.9",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
