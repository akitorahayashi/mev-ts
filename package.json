{
  "name": "mev",
  "version": "0.1.0",
  "description": "macOS development environment provisioning CLI",
  "packageManager": "bun@1.3.14",
  "module": "src/mev/main.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mev": "./src/mev/main.ts"
  },
  "scripts": {
    "mev": "bun src/mev/main.ts",
    "prebuild": "mkdir -p dist",
    "build": "bun build src/mev/main.ts --compile --outfile dist/mev && rm -f .*.bun-build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "cac": "6.7.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
