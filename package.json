{
  "name": "mev",
  "version": "0.1.0",
  "description": "Local IaC for macOS",
  "packageManager": "bun@1.3.14",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mev": "./src/main.ts"
  },
  "scripts": {
    "pree": "bun run codegen",
    "e": "bun src/main.ts",
    "up": "bun scripts/install-mev.ts",
    "codegen": "bun scripts/generate-assets.ts",
    "build": "bun scripts/build.ts --outfile dist/mev",
    "pretest": "bun run codegen",
    "test": "bun test",
    "pretest:unit": "bun run codegen",
    "test:unit": "bun test src",
    "pretest:integration": "bun run codegen",
    "test:integration": "bun test tests",
    "pretypecheck": "bun run codegen && bun scripts/validate-assets.ts",
    "typecheck": "tsc --noEmit",
    "precheck": "bun run codegen && bun scripts/validate-assets.ts",
    "check": "biome check . && tsc --noEmit",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.2.1",
    "clipanion": "4.0.0-rc.4",
    "js-yaml": "^5.1.0",
    "listr2": "^10.2.1",
    "mermaid": "11.16.0",
    "playwright-core": "1.61.1",
    "tty-prog": "github:akitorahayashi/tty-prog#v0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
